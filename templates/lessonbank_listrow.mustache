{{!
    @template mod_minilesson/lessonbank_listrow

    Single table row for list layout in lessonbank.

    Example context (json):
    {
    }
}}
<tr>
    <td class="imgcolumn"><img src="{{posterimage}}" alt="{{name}}" class="searchimg img-responsive"></td>
    <td>{{name}}</td>
    <td class="langcolumn">{{language}}</td>
    <td class="levelcolumn">{{languagelevel}}</td>
    <td class="keywordcolumn">{{keywords}}</td>
    <td>
        <p data-text={{#quote}}{{{description}}}{{/quote}}>
            <b class="mr-2">{{#str}}descriptioncolon, mod_minilesson{{/str}}</b>
            {{#shortentext}} 150, {{{description}}} {{/shortentext}}
        </p>
    </td>
    <td>{{itemcount}}</td>
    <td>
        <div class="d-flex flex-column align-items-center" style="gap:6px">
            {{#nativelanguage}}
                <a data-translateimportid="{{id}}" data-sourcelanguage="{{{nativelanguage}}}" data-action="translate" class="btn itemcontainer__btn--outlined">
                    {{#str}}translatetoimport, mod_minilesson{{/str}}
                </a>
            {{/nativelanguage}}
            <a data-id="{{id}}" data-action="download" data-download="{{name}}" class="btn itemcontainer__btn--primary importlessonitembtn">
                {{#str}}import{{/str}}
            </a>
        </div>
    </td>
</tr>
