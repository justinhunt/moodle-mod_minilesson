{{!
    @template mod_minilesson/noitems

    No Item Selection

    Example context (json):
    {
    }
}}

<div class="mod_minilesson_noitems_msg" id="mod_minilesson_noitems_msg">
    <div class="py-3">
        <h3>{{#str}}noitems, mod_minilesson{{/str}}</h3>
        {{#showadditemlinks}}
            <div>{{#str}}letsadditems, mod_minilesson{{/str}}</div>
            <div class="noitem-flex-container">
                <div class="noitem-flex-item">
                    <a class="noitem-flex-item-container" href="{{additemurl}}">
                        <div class="noitem-flex-item-icon">
                            <img src="{{additemicon}}" alt="{{#str}}add{{/str}}" />
                        </div>
                        <span class="noitem-flex-item-url">{{#str}}add{{/str}}</span>
                    </a>
                    <div class="noitem-flex-item-description">
                        {{#str}}addlessonitem_desc, mod_minilesson{{/str}}
                    </div>
                </div>
                {{#showlessonbank}}
                    <div class="noitem-flex-item">
                        <a class="noitem-flex-item-container" href="{{lessonbankitemurl}}">
                            <div class="noitem-flex-item-icon">
                                <img src="{{lessonbankicon}}" alt="{{#str}}choose{{/str}}" />
                            </div>
                            <span class="noitem-flex-item-url">{{#str}}choose{{/str}}</span>
                        </a>
                        <div class="noitem-flex-item-description">
                            {{#str}}chooselessonitem_desc, mod_minilesson{{/str}}
                        </div>
                    </div>
                {{/showlessonbank}}
                <div class="noitem-flex-item">
                    <a class="noitem-flex-item-container" href="{{aiitemurl}}">
                        <div class="noitem-flex-item-icon">
                            <img src="{{aiitemicon}}" alt="{{#str}}generate, mod_minilesson{{/str}}" />
                        </div>
                        <span class="noitem-flex-item-url">{{#str}}generate, mod_minilesson{{/str}}</span>
                    </a>
                    <div class="noitem-flex-item-description">
                        {{#str}}generatelessonitem_desc, mod_minilesson{{/str}}
                    </div>
                </div>
            </div>
        {{/showadditemlinks}}
    </div>
</div>