    }
}}

<div class="mod_minilesson_noitems_msg" id="mod_minilesson_noitems_msg">
    <div class="py-3">
        <h3 class="still-no-items">{{#str}}noitems, mod_minilesson{{/str}}</h3>
        {{#showadditemlinks}}
            <div class="noitem-flex-container">
                <a class="noitem-flex-item noitem-add" href="{{additemurl}}">
                    <div class="noitem-flex-item-icon">
                        {{> mod_minilesson/icon_add }}
                        <svg class="add-round-icon" width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="25" cy="25" r="24.5" fill="white" stroke="#E4DFF1"/>
                            <path d="M23.86 15.14C23.86 14.51 24.37 14 25 14C25.63 14 26.14 14.51 26.14 15.14V34.86C26.14 35.49 25.63 36 25 36C24.37 36 23.86 35.49 23.86 34.86V15.14Z" fill="#AB83F4"/>
