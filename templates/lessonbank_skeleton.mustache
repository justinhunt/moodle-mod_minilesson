{{!
    @template mod_minilesson/lessonbank_skeleton

    Skeleton placeholder card shown during infinite scroll loading.

    Example context (json):
    {
    }
}}
<div class="col-md-6 lbsf-skeleton-card" data-region="itemcard">
    <div class="itemcontainer">
        <div class="row itemcontainer__body">
            <div class="col-xl-4">
                <div class="lbsf-skeleton lbsf-skeleton--image"></div>
            </div>
            <div class="col-xl-8">
                <div class="lbsf-skeleton lbsf-skeleton--title"></div>
                <div class="lbsf-skeleton lbsf-skeleton--meta"></div>
                <div class="lbsf-skeleton lbsf-skeleton--text"></div>
                <div class="lbsf-skeleton lbsf-skeleton--text lbsf-skeleton--short"></div>
                <div class="lbsf-skeleton lbsf-skeleton--tags"></div>
            </div>
        </div>
        <div class="itemcontainer__footer">
            <div class="lbsf-skeleton lbsf-skeleton--button"></div>
            <div class="lbsf-skeleton lbsf-skeleton--button"></div>
        </div>
    </div>
</div>
