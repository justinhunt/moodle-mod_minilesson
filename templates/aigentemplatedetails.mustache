{{!
    @template mod_minilesson/aigentemplatedetails

    Details view (modal body) for an AIGEN lesson template.

    Example context (json):
    {
        "description": "A lesson for practising vocabulary.",
        "itemcount": 3,
        "hasitemtypes": true,
        "itemtypes": [
            {"label": "Multiple choice", "count": 2},
            {"label": "Dictation", "count": 1}
        ],
        "hastags": true,
        "tags": [
            {"label": "Vocabulary Practice"},
            {"label": "Multi-Item"}
        ]
    }
}}
<div class="minilesson_templatedetails">
    {{#description}}
        <p class="minilesson_templatedetails_description">{{{description}}}</p>
    {{/description}}

    <div class="minilesson_templatedetails_itemcount mb-2">
        <strong>{{#str}} itemcount, mod_minilesson {{/str}}</strong> {{itemcount}}
    </div>

    {{#hasitemtypes}}
        <div class="minilesson_templatedetails_itemtypes mb-2">
            <h5>{{#str}} aigentemplate_itemtypes, mod_minilesson {{/str}}</h5>
            <ul class="list-unstyled mb-0">
                {{#itemtypes}}
                    <li>{{label}} <span class="badge badge-secondary">&times;{{count}}</span></li>
                {{/itemtypes}}
            </ul>
        </div>
    {{/hasitemtypes}}

    {{#hastags}}
        <div class="minilesson_templatedetails_tags">
            <h5>{{#str}} aigentemplate_tags, mod_minilesson {{/str}}</h5>
            <div class="minilesson_templatedetails_taglist">
                {{#tags}}
                    <span class="badge badge-info">{{label}}</span>
                {{/tags}}
            </div>
        </div>
    {{/hastags}}
</div>
