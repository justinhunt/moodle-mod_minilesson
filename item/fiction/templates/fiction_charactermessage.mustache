{{!
    @template minilessonitem_fiction/fiction_charactermessage

    A single character/narrator message bubble (plain & mobilechat modes).

    Example context (json):
    {
        "charactername": "Narrator",
        "charactertext": "Once upon a time...",
        "taptotranslate": true,
        "taptotranslatearia": "Translate this text",
        "translatesource": "Once upon a time..."
    }
}}
<div class="d-flex chat-window">
    {{#picturesrc}}
        <div class="character_profile_icon">
            <img class="character_profile_icon-image" src="{{{ . }}}">
        </div>
    {{/picturesrc}}
    <div class="charactercontainer {{classname}} {{#charactername}}has-charactername{{/charactername}}">
        {{#charactername}}
            <div class="charactername text-primary pt-2">{{{ . }}}</div>
        {{/charactername}}
        {{^charactername}}
            <div class="pt-2"></div>
        {{/charactername}}
        {{#charactermedia}}
            <div class="mediacontainer">{{{ . }}}</div>
        {{/charactermedia}}
        {{#charactertext}}
            <div class="charactertext">{{{ . }}}</div>
        {{/charactertext}}
        {{#taptotranslate}}
            <button type="button" class="fiction-translate-icon" aria-label="{{taptotranslatearia}}"
                title="{{taptotranslatearia}}" data-translatetext="{{translatesource}}">
                <i class="fa fa-language" aria-hidden="true"></i>
            </button>
        {{/taptotranslate}}
    </div>
</div>